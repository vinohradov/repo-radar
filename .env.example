# Copy to .env and fill in. The server reads these at startup.

# Required for the AI agent layer. Without it, scans run the deterministic
# collectors only and mark the analyze phase as skipped (no crash).
ANTHROPIC_API_KEY=

# Default model for all agents (override per-agent on the Settings page).
REPO_RADAR_MODEL=claude-opus-4-8

# Server port (client dev server proxies /api to this).
PORT=8787

# Hard per-scan output-token budget; the pipeline aborts the analyze phase
# if exceeded. Keeps PoC costs bounded.
REPO_RADAR_MAX_OUTPUT_TOKENS_PER_SCAN=60000
